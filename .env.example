# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_GENERAL=gpt-5.6-terra
OPENAI_MODEL_JUDGE=gpt-5.6-sol
# Modelo de transcripción de voz (entrada por audio). Opcional.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_AGENTS_DONT_LOG_MODEL_DATA=1
OPENAI_AGENTS_DONT_LOG_TOOL_DATA=1

# Supabase (servidor/worker)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Alias legado; puede usarse en lugar de SUPABASE_SECRET_KEY.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (web; solo la anon key puede exponerse al navegador)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Motor y worker
MAX_CLAIMS=3
CLAIM_CONCURRENCY=3
JOB_CONCURRENCY=1
POLL_INTERVAL_MS=2000
LEASE_SECONDS=120
LEASE_RENEW_INTERVAL_MS=30000
MAX_ATTEMPTS=3
ANALYSIS_TIMEOUT_MS=600000
EMIT_LEGACY_V1=true
PORT=3001
LOG_LEVEL=info

# API web
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_SALT=cambia-esto-por-un-valor-aleatorio-largo
NEXT_PUBLIC_APP_URL=http://localhost:3000
