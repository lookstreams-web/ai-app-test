{
  "name": "motor-de-verdad",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:worker": "pnpm --filter @motor/analysis-worker dev",
    "build": "pnpm -r build && next build",
    "build:web": "next build",
    "start": "next start",
    "start:worker": "pnpm --filter @motor/analysis-worker start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:youtube": "tsx scripts/test-youtube.ts",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter @motor/analysis-contracts build && pnpm --filter @motor/analysis-engine build && pnpm --filter @motor/analysis-worker typecheck && tsc --noEmit"
  },
  "dependencies": {
    "@mantine/core": "^8.1.0",
    "@mantine/hooks": "^8.1.0",
    "@motor/analysis-contracts": "workspace:*",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.95.3",
    "dotenv": "^17.3.1",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "youtube-transcript": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^15.5.20",
    "@types/node": "^24.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.2",
    "postcss": "^8.4.47",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.9.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.18"
  }
}
